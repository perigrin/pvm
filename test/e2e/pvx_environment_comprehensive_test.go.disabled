	defer env.Cleanup()

	helpers.SkipIfNoSystemPerl(t)

	t.Run("InvalidPerlVersion", func(t *testing.T) {
		// Test error handling when PVM_PERL_VERSION is set to an invalid version
		config := &helpers.EnvironmentTestConfig{
			TestName:    "InvalidPerlVersion",
			Description: "Test error handling with invalid PVM_PERL_VERSION",
			EnvVars: map[string]string{
				"PVM_PERL_VERSION": "5.99.0", // Invalid version
			},
			Command:       "print 'test'",
			ExpectedError: true,
		}

		helpers.TestPVXEnvironmentInheritance(t, env, config)
	})

	t.Run("MissingPerlVersion", func(t *testing.T) {
		// Test behavior when PVM_PERL_VERSION is set to a missing version

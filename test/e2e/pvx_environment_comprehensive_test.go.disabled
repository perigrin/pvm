		}

		helpers.TestPVXEnvironmentInheritance(t, env, config)
	})
}

// TestPVXEnvironmentPerformance tests environment inheritance performance
func TestPVXEnvironmentPerformance(t *testing.T) {
	// SKIPPED: env := helpers.NewTestEnv(t)
	t.Skip("Skipping comprehensive test - causes resource contention in CI")
	defer env.Cleanup()

	helpers.SkipIfNoSystemPerl(t)

	t.Run("EnvironmentInheritancePerformance", func(t *testing.T) {
		// Test that environment inheritance doesn't significantly impact performance
		config := &helpers.EnvironmentTestConfig{
			TestName:    "EnvironmentInheritancePerformance",
			Description: "Test environment inheritance performance",
			EnvVars: map[string]string{
				"PVM_PERL_VERSION": "5.42.0",
			},
			Command: "print 'performance test'",
			ShouldContain: []string{
				"performance test",
			},
		}

		// Run the test multiple times to check for performance consistency
		for i := 0; i < 3; i++ {
			helpers.TestPVXEnvironmentInheritance(t, env, config)
		}
	})

	t.Run("LargeEnvironmentInheritance", func(t *testing.T) {
		// Test inheritance with a large number of environment variables
		largeEnvVars := make(map[string]string)
		for i := 0; i < 50; i++ {
			largeEnvVars[fmt.Sprintf("TEST_VAR_%d", i)] = fmt.Sprintf("value_%d", i)
		}
		largeEnvVars["PVM_PERL_VERSION"] = "5.42.0"

		config := &helpers.EnvironmentTestConfig{
			TestName:    "LargeEnvironmentInheritance",
			Description: "Test inheritance with large number of environment variables",
			EnvVars:     largeEnvVars,
			Command:     "print 'large environment test'",
			ShouldContain: []string{
				"large environment test",
			},
		}

		helpers.TestPVXEnvironmentInheritance(t, env, config)
	})
}

	t.Skip("Skipping isolation levels test - causes resource contention in CI")

	t.Run("IsolationLevelEnvironment", func(t *testing.T) {
		// This subtest is skipped with the parent
		t.Skip("Parent test skipped")
	})

	t.Run("GlobalIsolationPreservesAll", func(t *testing.T) {
		// This subtest is skipped with the parent
		t.Skip("Parent test skipped")
	})

	t.Run("LocalIsolationPreservesEnvironment", func(t *testing.T) {
		// This subtest is skipped with the parent
		t.Skip("Parent test skipped")
		config := &helpers.EnvironmentTestConfig{
			TestName:       "LocalIsolationPreservesEnvironment",
			Description:    "Test that local isolation preserves environment variables",
			IsolationLevel: "local",
			EnvVars: map[string]string{
				"TEST_CUSTOM_VAR":  "custom_value",
				"PVM_PERL_VERSION": "5.42.0",
			},
			Command: "print join(',', $ENV{TEST_CUSTOM_VAR} || 'undefined', $ENV{PVM_PERL_VERSION} || 'undefined')",
			ShouldContain: []string{
				"custom_value,5.42.0",
			},
		}

		helpers.TestPVXEnvironmentInheritance(t, env, config)
	})

	t.Run("CleanIsolationPreservesPVMVariables", func(t *testing.T) {
		config := &helpers.EnvironmentTestConfig{
			TestName:       "CleanIsolationPreservesPVMVariables",
			Description:    "Test that clean isolation preserves PVM-specific variables",
			IsolationLevel: "clean",
			EnvVars: map[string]string{
				"TEST_CUSTOM_VAR":  "custom_value",
				"PVM_PERL_VERSION": "5.42.0",
			},
			Command: "print join(',', $ENV{TEST_CUSTOM_VAR} || 'undefined', $ENV{PVM_PERL_VERSION} || 'undefined')",
			ShouldContain: []string{
				"undefined,5.42.0", // Custom var should be filtered, but PVM var should be preserved
			},
		}

		helpers.TestPVXEnvironmentInheritance(t, env, config)
	})
}


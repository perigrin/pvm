[
  {
    "name": "Multiple Type Constraints",
    "description": "Test parsing of multiple type constraints on type parameters",
    "tests": [
      {
        "input": "method transform<T, U>(T $input) -> U where T: Serializable&Defined, U: Deserializable&!Undef {\n    return deserialize($input->serialize());\n}",
        "expected_type_annotations": [
          {
            "kind": "MethodParamAnnotation",
            "item": "$input",
            "type": "T",
            "constraints": [
              {
                "parameter": "T",
                "kind": "TypeConstraint",
                "expression": "Serializable&Defined"
              },
              {
                "parameter": "U", 
                "kind": "TypeConstraint",
                "expression": "Deserializable&!Undef"
              }
            ]
          },
          {
            "kind": "MethodReturnAnnotation",
            "item": "transform",
            "type": "U"
          }
        ]
      },
      {
        "input": "method complex<T, U>(T $input, CodeRef[T, U] $transform) -> U where T: (Serializable|Storable)&Defined, U: !Undef {\n    return $transform->($input);\n}",
        "expected_type_annotations": [
          {
            "kind": "MethodParamAnnotation",
            "item": "$input",
            "type": "T"
          },
          {
            "kind": "MethodParamAnnotation", 
            "item": "$transform",
            "type": "CodeRef[T, U]",
            "constraints": [
              {
                "parameter": "T",
                "kind": "TypeConstraint",
                "expression": "(Serializable|Storable)&Defined"
              },
              {
                "parameter": "U",
                "kind": "TypeConstraint", 
                "expression": "!Undef"
              }
            ]
          }
        ]
      }
    ]
  }
]
[
  {
    "name": "Basic Type Constraints",
    "description": "Test basic type constraint parsing with where clauses",
    "tests": [
      {
        "input": "method process<T>(ArrayRef[T] $data) -> ArrayRef[T] where T: Serializable {\n    return $data;\n}",
        "expected_type_annotations": [
          {
            "kind": "MethodParamAnnotation", 
            "item": "$data",
            "type": "ArrayRef[T]",
            "constraints": [
              {
                "parameter": "T",
                "kind": "TypeConstraint",
                "expression": "Serializable"
              }
            ]
          },
          {
            "kind": "MethodReturnAnnotation",
            "item": "process",
            "type": "ArrayRef[T]"
          }
        ]
      },
      {
        "input": "method calculate<T>(T $input) -> T where T: Numeric {\n    return $input + 1;\n}",
        "expected_type_annotations": [
          {
            "kind": "MethodParamAnnotation",
            "item": "$input", 
            "type": "T",
            "constraints": [
              {
                "parameter": "T",
                "kind": "TypeConstraint", 
                "expression": "Numeric"
              }
            ]
          }
        ]
      },
      {
        "input": "class Container<T> where T: Clonable {\n    field ArrayRef[T] $items;\n}",
        "expected_type_annotations": [
          {
            "kind": "FieldAnnotation",
            "item": "$items",
            "type": "ArrayRef[T]",
            "constraints": [
              {
                "parameter": "T", 
                "kind": "TypeConstraint",
                "expression": "Clonable"
              }
            ]
          }
        ]
      }
    ]
  }
]
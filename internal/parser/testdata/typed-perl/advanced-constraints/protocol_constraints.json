[
  {
    "name": "Protocol Constraints",
    "description": "Test parsing of protocol and capability constraints",
    "tests": [
      {
        "input": "method handle<T>(T $object) -> ProcessResult where T does EventHandler {\n    return $object->process();\n}",
        "expected_type_annotations": [
          {
            "kind": "MethodParamAnnotation",
            "item": "$object",
            "type": "T",
            "constraints": [
              {
                "parameter": "T",
                "kind": "ProtocolConstraint",
                "expression": "EventHandler"
              }
            ]
          }
        ]
      },
      {
        "input": "method process<T>(T $obj) -> Bool where T can 'serialize' {\n    return defined($obj->serialize());\n}",
        "expected_type_annotations": [
          {
            "kind": "MethodParamAnnotation",
            "item": "$obj", 
            "type": "T",
            "constraints": [
              {
                "parameter": "T",
                "kind": "CapabilityConstraint",
                "expression": "'serialize'"
              }
            ]
          }
        ]
      },
      {
        "input": "method advanced<T>(T $input) -> T where T does Serializable, T can 'process', T->VERSION >= 1.5 {\n    return $input->process();\n}",
        "expected_type_annotations": [
          {
            "kind": "MethodParamAnnotation",
            "item": "$input",
            "type": "T",
            "constraints": [
              {
                "parameter": "T",
                "kind": "ProtocolConstraint", 
                "expression": "Serializable"
              },
              {
                "parameter": "T",
                "kind": "CapabilityConstraint",
                "expression": "'process'"
              },
              {
                "parameter": "T",
                "kind": "VersionConstraint",
                "expression": "T->VERSION >= 1.5"
              }
            ]
          }
        ]
      }
    ]
  }
]
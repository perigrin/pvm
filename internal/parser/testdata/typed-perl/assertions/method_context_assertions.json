{
  "name": "method_context_assertions",
  "description": "Type assertions within method definitions and calls",
  "test_cases": [
    {
      "input": "method process($input) {\n    my $typed = $input as ArrayRef[Str];\n    return $typed;\n}",
      "expected": {
        "type": "method_definition",
        "name": "process",
        "parameters": [
          {
            "name": "$input",
            "type": null
          }
        ],
        "body": {
          "type": "block_statement",
          "statements": [
            {
              "type": "variable_declaration",
              "variable_name": "$typed",
              "assignment": {
                "type": "type_assertion",
                "expression": {
                  "type": "variable_expression",
                  "name": "$input"
                },
                "target_type": {
                  "type": "parameterized_type",
                  "name": "ArrayRef",
                  "parameters": [
                    {
                      "type": "simple_type",
                      "name": "Str"
                    }
                  ]
                }
              }
            },
            {
              "type": "return_statement",
              "expression": {
                "type": "variable_expression",
                "name": "$typed"
              }
            }
          ]
        }
      }
    },
    {
      "input": "$self->{count} = $new_value as Int;",
      "expected": {
        "type": "assignment_expression",
        "left": {
          "type": "hash_access",
          "hash": {
            "type": "variable_expression",
            "name": "$self"
          },
          "key": {
            "type": "bareword",
            "value": "count"
          }
        },
        "right": {
          "type": "type_assertion",
          "expression": {
            "type": "variable_expression",
            "name": "$new_value"
          },
          "target_type": {
            "type": "simple_type",
            "name": "Int"
          }
        },
        "operator": "="
      }
    }
  ]
}
{
  "name": "expression_context_assertions",
  "description": "Type assertions in various expression contexts",
  "test_cases": [
    {
      "input": "my $result = ($calculation + $offset) as Num;",
      "expected": {
        "type": "variable_declaration",
        "variable_name": "$result",
        "assignment": {
          "type": "type_assertion",
          "expression": {
            "type": "parenthesized_expression",
            "inner": {
              "type": "binary_expression",
              "operator": "+",
              "left": {
                "type": "variable_expression",
                "name": "$calculation"
              },
              "right": {
                "type": "variable_expression",
                "name": "$offset"
              }
            }
          },
          "target_type": {
            "type": "simple_type",
            "name": "Num"
          }
        }
      }
    },
    {
      "input": "my $item = $array->[$index] as ItemType;",
      "expected": {
        "type": "variable_declaration",
        "variable_name": "$item",
        "assignment": {
          "type": "type_assertion",
          "expression": {
            "type": "array_access",
            "array": {
              "type": "variable_expression",
              "name": "$array"
            },
            "index": {
              "type": "variable_expression",
              "name": "$index"
            }
          },
          "target_type": {
            "type": "simple_type",
            "name": "ItemType"
          }
        }
      }
    },
    {
      "input": "my $value = $maybe_number as Int // 0;",
      "expected": {
        "type": "variable_declaration",
        "variable_name": "$value",
        "assignment": {
          "type": "binary_expression",
          "operator": "//",
          "left": {
            "type": "type_assertion",
            "expression": {
              "type": "variable_expression",
              "name": "$maybe_number"
            },
            "target_type": {
              "type": "simple_type",
              "name": "Int"
            }
          },
          "right": {
            "type": "number_literal",
            "value": "0"
          }
        }
      }
    }
  ]
}
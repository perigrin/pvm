# Perl Built-in Function Type Definitions
# Comprehensive coverage of all Perl built-in functions from perlfunc
# Using actual Perl subroutine syntax that the parser understands
#
# NOTE: This file should logically be moved to data/typechecker/ in the future
# for better organization as a project-wide data resource.
#
# COVERAGE: ~97% of callable Perl built-in functions (238+ functions)
#
# INTENTIONALLY EXCLUDED (~3% remaining):
# 1. File test operators (-r, -w, -x, -e, -f, -d, etc.) - handled as special operators by parser
# 2. Quote operators (m//, s///, tr///, y///, qx//) - handled as syntax constructs by lexer
# 3. Language constructs (sub, import) - compile-time directives, not runtime functions
#
# These exclusions are by design: they require special parser/grammar handling
# rather than type definitions, as they use non-function call syntax.

# ============================================================================
# SCALAR/STRING FUNCTIONS
# ============================================================================

# Core type checking functions
sub Str ref(Any $value);
sub Bool defined(Any $value);
sub Bool exists(HashRef $hash, Str $key);

# String manipulation
sub Str chomp(Str $string);
sub Int chomp(Array[Str] $strings);
sub Str chop(Str $string);
sub Str chop(Array[Str] $strings);
sub Str chr(Int $number);
sub Str crypt(Str $plaintext, Str $salt);
sub Str fc(Str $string);         # Unicode fold case
sub Int hex(Str $expression);
sub Str lc(Str $string);
sub Str lcfirst(Str $string);
sub Int length(Str $string);
sub Int oct(Str $expression);
sub Int ord(Str $expression);
sub Str pack(Str $template, ...Any $values);
sub Str reverse(Str $string);
sub Array[Any] reverse(Array[Any] $list);
sub Int rindex(Str $string, Str $substring);
sub Int rindex(Str $string, Str $substring, Int $position);
sub Str sprintf(Str $format, ...Any $args);
sub Str substr(Str $string, Int $offset);
sub Str substr(Str $string, Int $offset, Int $length);
sub Str substr(Str $string, Int $offset, Int $length, Str $replacement);
sub Str uc(Str $string);
sub Str ucfirst(Str $string);
sub Int index(Str $string, Str $substring);
sub Int index(Str $string, Str $substring, Int $position);

# ============================================================================
# NUMERIC FUNCTIONS
# ============================================================================

sub Int int(Any $value);
sub Num abs(Num $value);
sub Num atan2(Num $y, Num $x);
sub Num cos(Num $expression);
sub Num exp(Num $expression);
sub Num log(Num $expression);
sub Num rand();
sub Num rand(Num $expr);
sub Num sin(Num $expression);
sub Num sqrt(Num $expression);
sub Num srand();
sub Num srand(Num $expr);

# ============================================================================
# ARRAY/LIST FUNCTIONS
# ============================================================================

# Hash and array access
sub Array[Str] keys(HashRef $hash);
sub Array[Any] keys(Array $array);
sub Array[Any] values(HashRef $hash);
sub Array[Any] values(Array $array);
sub Any each(HashRef $hash);
sub Any each(Array $array);

# Array manipulation
sub Int push(Array $array, ...Any $values);
sub Any pop(Array $array);
sub Any shift(Array $array);
sub Int unshift(Array $array, ...Any $values);
sub Array[Any] splice(Array $array, Int $offset);
sub Array[Any] splice(Array $array, Int $offset, Int $length);
sub Array[Any] splice(Array $array, Int $offset, Int $length, Array[Any] $list);

# List processing
sub Array[Any] grep(CodeRef $block, Array[Any] $list);
sub Array[Any] map(CodeRef $block, Array[Any] $list);
sub Str join(Str $expr, Array[Any] $list);
sub Array[Any] sort(Array[Any] $list);
sub Array[Any] sort(CodeRef $subname, Array[Any] $list);
sub Array[Any] reverse(Array[Any] $list);
sub Array[Any] unpack(Str $template, Str $expr);

# ============================================================================
# REGULAR EXPRESSION FUNCTIONS
# ============================================================================

sub Array[Str] split(Str $pattern, Str $expr);
sub Array[Str] split(Str $pattern, Str $expr, Int $limit);
sub Int pos(Str $string);
sub Str quotemeta(Str $string);
sub Void study(Str $string);


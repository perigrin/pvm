sub Int sysread(FileHandle $fh, Str $buffer, Int $length, Int $offset);
sub Int syswrite(FileHandle $fh, Str $buffer);
sub Int syswrite(FileHandle $fh, Str $buffer, Int $length);
sub Int syswrite(FileHandle $fh, Str $buffer, Int $length, Int $offset);

# Output functions

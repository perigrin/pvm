# ============================================================================
# FILE TEST OPERATORS
# ============================================================================
# NOTE: These are provided for completeness but are typically handled as
# special operators by the parser, not as function calls. In real Perl:
#   if (-f $filename)  # operator syntax
# not:
#   if (file_test_f($filename))  # function call syntax
#
# These definitions allow type checking when file tests are used in
# function-call style, but the parser should handle the operator forms.

# File existence and type tests
sub Bool file_test_r(Str $filename);  # -r readable
sub Bool file_test_w(Str $filename);  # -w writable
sub Bool file_test_x(Str $filename);  # -x executable
sub Bool file_test_e(Str $filename);  # -e exists
sub Bool file_test_f(Str $filename);  # -f plain file
sub Bool file_test_d(Str $filename);  # -d directory
sub Bool file_test_l(Str $filename);  # -l symbolic link
sub Bool file_test_s(Str $filename);  # -s size
sub Bool file_test_z(Str $filename);  # -z zero size

# Special file types
sub Bool file_test_p(Str $filename);  # -p named pipe
sub Bool file_test_S(Str $filename);  # -S socket
sub Bool file_test_b(Str $filename);  # -b block device
sub Bool file_test_c(Str $filename);  # -c character device
sub Bool file_test_t(FileHandle $fh); # -t terminal

# Permission tests
sub Bool file_test_u(Str $filename);  # -u setuid
sub Bool file_test_g(Str $filename);  # -g setgid
sub Bool file_test_k(Str $filename);  # -k sticky bit
sub Bool file_test_o(Str $filename);  # -o owned by effective uid
sub Bool file_test_O(Str $filename);  # -O owned by real uid
sub Bool file_test_R(Str $filename);  # -R readable by real uid
sub Bool file_test_W(Str $filename);  # -W writable by real uid
sub Bool file_test_X(Str $filename);  # -X executable by real uid

# File content tests
sub Bool file_test_T(Str $filename);  # -T text file
sub Bool file_test_B(Str $filename);  # -B binary file

# File age tests (days since last access/modification/inode change)
sub Num file_test_M(Str $filename);   # -M modification age
sub Num file_test_A(Str $filename);   # -A access age
sub Num file_test_C(Str $filename);   # -C inode change age

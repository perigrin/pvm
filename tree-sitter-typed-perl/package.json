{
  "name": "tree-sitter-typed-perl",
  "version": "1.0.0",
  "description": "A tree-sitter parser for Typed Perl with type annotations",
  "main": "bindings/node",
  "types": "bindings/node",
  "scripts": {
    "dev-install": "npm install --no-save tree-sitter-cli",
    "generate": "tree-sitter generate",
    "test": "tree-sitter generate && tree-sitter test",
    "build": "npm run generate && npm run fix-scanner",
    "fix-scanner": "sed -i '' 's/tree_sitter_perl_external_scanner/tree_sitter_typed_perl_external_scanner/g' src/scanner.c",
    "install": "node-gyp-build",
    "prebuildify": "prebuildify --napi --strip"
  },
  "engines": {
    "node": ">= 20.0.0"
  },
  "author": "veesh",
  "license": "ISC",
  "dependencies": {
    "node-addon-api": "^7.1.0",
    "node-gyp-build": "^4.8.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.21.0"
  },
  "peerDependenciesMeta": {
    "tree_sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "eslint": "^8.21.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-n": "^15.2.4",
    "eslint-plugin-promise": "^6.0.0",
    "prebuildify": "^6.0.0",
    "tree-sitter-cli": "^0.24.2"
  },
  "files": [
    "grammar.js",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/*",
    "src/**"
  ],
  "tree-sitter": [
    {
      "scope": "source.perl",
      "injection-regex": "^perl$"
    }
  ]
}
